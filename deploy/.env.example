# OpenClaw 部署环境变量配置示例
# 复制此文件为 .env 并根据需要修改

# === 基础配置 ===
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_GATEWAY_BIND=lan

# === 路径配置 ===
OPENCLAW_CONFIG_DIR=${HOME}/.openclaw
OPENCLAW_WORKSPACE_DIR=${HOME}/.openclaw/workspace

# === 安全令牌 (自动生成，或在此设置固定值) ===
# OPENCLAW_GATEWAY_TOKEN=your-secret-token-here

# === 镜像配置 ===
# Docker/Podman 使用: openclaw:local
# DinD 使用: openclaw:dind
OPENCLAW_IMAGE=openclaw:local

# === 自定义依赖包 ===
# 空格分隔的 Alpine (DinD) 或 Debian (标准) 包名
# 示例: OPENCLAW_DOCKER_APT_PACKAGES="ffmpeg curl jq"
OPENCLAW_DOCKER_APT_PACKAGES=

# === 扩展预安装 ===
# 空格分隔的扩展目录名
# 示例: OPENCLAW_EXTENSIONS="diagnostics-otel matrix"
OPENCLAW_EXTENSIONS=

# === 时区 ===
OPENCLAW_TZ=UTC

# === DinD 专用配置 ===
# 是否需要特权模式 (DinD 必需)
# OPENCLAW_DIND_PRIVILEGED=1
